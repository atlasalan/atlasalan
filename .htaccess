# GameZone - Apache Ayarları

# PHP dosyalarını games/ klasöründe çalıştırma
<Directory "games">
    php_flag engine off
    AddType text/plain .php .php3 .php4 .php5 .phtml
</Directory>

# games.json'u dışarıdan gizle
<Files "games.json">
    Order allow,deny
    Deny from all
</Files>

# Dizin listesini kapat
Options -Indexes

# Büyük dosya yüklemeye izin ver (512MB)
php_value upload_max_filesize 512M
php_value post_max_size 512M
php_value max_execution_time 300
php_value max_input_time 300
